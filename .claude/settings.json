{
  "version": "1.0",
  "hooks": [
    {
      "id": "blend-auto-export",
      "name": "Auto-Export Blender Assets",
      "description": "Runs asset pipeline when any .blend file is saved",
      "enabled": true,
      "trigger": {
        "type": "file_pattern_change",
        "patterns": [
          "**/*.blend",
          "**/*.blend.blend"
        ],
        "events": ["modified", "saved"],
        "debounce_ms": 2000
      },
      "action": {
        "type": "script",
        "command": "powershell",
        "args": [
          "-NoProfile",
          "-ExecutionPolicy",
          "Bypass",
          "-File",
          ".\\scripts\\smart_asset_export.ps1",
          "-BlendFilePath",
          "${FILE_PATH}"
        ],
        "cwd": "${WORKSPACE_ROOT}",
        "timeout_seconds": 300,
        "capture_output": true,
        "on_success": {
          "notify": true,
          "message": "Asset exported successfully",
          "level": "info"
        },
        "on_failure": {
          "notify": true,
          "message": "Asset export failed - check logs",
          "level": "error"
        }
      }
    },
    {
      "id": "drone-control-regression-check",
      "name": "Drone Control Regression Check",
      "description": "Runs focused gameplay checks when drone input, pilot control, HUD loadout, or drone prefab files change",
      "enabled": true,
      "trigger": {
        "type": "file_pattern_change",
        "patterns": [
          "Code/Drone/DroneWeapon.cs",
          "Code/Player/DroneDeployer.cs",
          "Code/Player/PilotSoldier.cs",
          "Code/Player/RemoteController.cs",
          "Code/UI/HudPanel.razor",
          "Assets/prefabs/drone_fpv.prefab",
          "Assets/prefabs/drone_fpv_fiber.prefab",
          "Assets/prefabs/pilot_ground.prefab",
          "scripts/check_drone_kamikaze_primary.ps1",
          "scripts/check_loadout_slots.ps1",
          "scripts/agents/gameplay_regression_guard.ps1"
        ],
        "events": ["modified", "saved"],
        "debounce_ms": 1000
      },
      "action": {
        "type": "script",
        "command": "powershell",
        "args": [
          "-NoProfile",
          "-ExecutionPolicy",
          "Bypass",
          "-File",
          ".\\scripts\\agents\\gameplay_regression_guard.ps1",
          "-Root",
          "${WORKSPACE_ROOT}"
        ],
        "cwd": "${WORKSPACE_ROOT}",
        "timeout_seconds": 90,
        "capture_output": true,
        "on_success": {
          "notify": true,
          "message": "Drone control checks passed",
          "level": "info"
        },
        "on_failure": {
          "notify": true,
          "message": "Drone control regression check failed",
          "level": "error"
        }
      }
    },
    {
      "id": "sbox-editor-first-workflow-check",
      "name": "S&Box Editor-First Workflow Check",
      "description": "Runs editor-first workflow routing checks when MCP docs, agent routing, hooks, or suite wiring change",
      "enabled": true,
      "trigger": {
        "type": "file_pattern_change",
        "patterns": [
          "AGENTS.md",
          ".mcp.json",
          "docs/editor_control_plane.md",
          "docs/agent_toolkit.md",
          "docs/known_sbox_patterns.md",
          ".agents/sbox/README.md",
          ".agents/sbox/editor-first-workflow-agent.md",
          "scripts/agents/editor_first_workflow_audit.ps1",
          "scripts/agents/run_agent_checks.ps1",
          "scripts/agents/post_task_training_agent.ps1",
          "scripts/agents/test_full_automation_layer.ps1"
        ],
        "events": ["modified", "saved"],
        "debounce_ms": 1500
      },
      "action": {
        "type": "script",
        "command": "powershell",
        "args": [
          "-NoProfile",
          "-ExecutionPolicy",
          "Bypass",
          "-File",
          ".\\scripts\\agents\\run_agent_checks.ps1",
          "-Root",
          "${WORKSPACE_ROOT}",
          "-Suite",
          "editor-first",
          "-ShowInfo"
        ],
        "cwd": "${WORKSPACE_ROOT}",
        "timeout_seconds": 90,
        "capture_output": true,
        "on_success": {
          "notify": false,
          "message": "S&Box editor-first workflow checks passed",
          "level": "info"
        },
        "on_failure": {
          "notify": true,
          "message": "S&Box editor-first workflow check failed",
          "level": "error"
        }
      }
    },
    {
      "id": "sbox-engine-reference-check",
      "name": "S&Box Engine/API Reference Check",
      "description": "Runs stale engine-guidance and local API-reference checks when docs, agent routing, API dump, or reference audits change",
      "enabled": true,
      "trigger": {
        "type": "file_pattern_change",
        "patterns": [
          "AGENTS.md",
          "docs/**/*.md",
          ".agents/sbox/*.md",
          "API.json",
          "api.json",
          "scripts/agents/sbox_engine_reference_audit.ps1",
          "scripts/agents/sbox_api_lookup.ps1",
          "scripts/agents/sbox_api_reference_audit.ps1",
          "scripts/agents/sbox_learn_intake_audit.ps1",
          "scripts/agents/ui_flow_audit.ps1",
          "scripts/agents/run_agent_checks.ps1",
          "scripts/agents/post_task_training_agent.ps1",
          "scripts/agents/test_full_automation_layer.ps1"
        ],
        "events": ["modified", "saved"],
        "debounce_ms": 1500
      },
      "action": {
        "type": "script",
        "command": "powershell",
        "args": [
          "-NoProfile",
          "-ExecutionPolicy",
          "Bypass",
          "-File",
          ".\\scripts\\agents\\run_agent_checks.ps1",
          "-Root",
          "${WORKSPACE_ROOT}",
          "-Suite",
          "docs",
          "-ShowInfo"
        ],
        "cwd": "${WORKSPACE_ROOT}",
        "timeout_seconds": 90,
        "capture_output": true,
        "on_success": {
          "notify": false,
          "message": "S&Box engine/API reference checks passed",
          "level": "info"
        },
        "on_failure": {
          "notify": true,
          "message": "S&Box engine/API reference check failed",
          "level": "error"
        }
      }
    },
    {
      "id": "sbox-learn-intake-check",
      "name": "S&Box Learn Intake Check",
      "description": "Runs tutorial-intake and Razor reactivity checks when Learn-derived docs, agents, hooks, or UI audit rules change",
      "enabled": true,
      "trigger": {
        "type": "file_pattern_change",
        "patterns": [
          "docs/sbox_engine_llm_reference.md",
          "docs/known_sbox_patterns.md",
          "docs/agent_toolkit.md",
          ".agents/sbox/sbox-learn-intake-agent.md",
          ".agents/sbox/sbox-engine-reference-agent.md",
          ".agents/sbox/ui-razor-reactivity-agent.md",
          ".agents/sbox/ui-flow-agent.md",
          ".agents/sbox/README.md",
          "scripts/agents/sbox_learn_intake_audit.ps1",
          "scripts/agents/ui_flow_audit.ps1",
          "scripts/agents/run_agent_checks.ps1",
          "scripts/agents/post_task_training_agent.ps1",
          "scripts/agents/test_full_automation_layer.ps1"
        ],
        "events": ["modified", "saved"],
        "debounce_ms": 1500
      },
      "action": {
        "type": "script",
        "command": "powershell",
        "args": [
          "-NoProfile",
          "-ExecutionPolicy",
          "Bypass",
          "-File",
          ".\\scripts\\agents\\run_agent_checks.ps1",
          "-Root",
          "${WORKSPACE_ROOT}",
          "-Suite",
          "learn",
          "-ShowInfo"
        ],
        "cwd": "${WORKSPACE_ROOT}",
        "timeout_seconds": 90,
        "capture_output": true,
        "on_success": {
          "notify": false,
          "message": "S&Box Learn intake checks passed",
          "level": "info"
        },
        "on_failure": {
          "notify": true,
          "message": "S&Box Learn intake check failed",
          "level": "error"
        }
      }
    }
  ]
}
