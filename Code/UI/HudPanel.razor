@using Sandbox
@using Sandbox.UI
@using System
@using System.Collections.Generic
@using System.Linq
@using DroneVsPlayers
@namespace DroneVsPlayers
@inherits PanelComponent

@*
   In-game HUD. Attach this PanelComponent to a GameObject in main.scene
   (typically the same GameManager object) so it renders for every client.

   The HUD is composed of child razor panels under Code/UI/Hud/. HudPanel owns
   all state, input handling, scene-lookup caching (HudPanel.Cache.cs), and
   Health event subscriptions; the children are pure presenters that read
   state through their Hud parameter and own their slice of BuildHash, so an
   idle section stops rebuilding without dragging the whole HUD with it.

   Shows:
     - top center: round state and countdown timer (RoundStatePanel)
     - top right: score + kill feed (KillFeedPanel)
     - center: crosshair, hitmarker, prompts, damage arcs (ReticlePanel)
     - bottom left: local health bar (HealthPanel)
     - loadout + ammo readouts (LoadoutPanel + AmmoHudRenderer)
     - Tab: full scoreboard overlay
     - Escape: local options overlay (OptionsOverlayPanel)
     - main menu + role picker (MainMenuShellPanel / RolePickerPanel)
     - low HP: vignette; jam/suppression/sun-glare/eliminated alerts
*@

<root>
    <div class="hud @VignetteClass">
        @if ( ShowMainMenuShell )
        {
            <MainMenuShellPanel Hud=@this />
        }

        @if ( ShowRolePicker )
        {
            <RolePickerPanel Hud=@this />
        }

        @if ( !GameplayUiBlocked && ShowJamWarning )
        {
            <div class="jam-warning">SIGNAL JAMMED</div>
        }

        @if ( !GameplayUiBlocked && SuppressionOpacity > 0.01f )
        {
            <div class="suppression-vignette" style="opacity: @SuppressionOpacity.ToString("0.00")"></div>
        }

        @if ( !GameplayUiBlocked && SunGlareOpacity > 0.01f )
        {
            <div class="sun-glare" style="opacity: @SunGlareOpacity.ToString("0.00")"></div>
        }

        @if ( !GameplayUiBlocked && EliminatedVisible )
        {
            <div class="eliminated-popup">
                <div class="eliminated-label">ELIMINATED</div>
                <div class="eliminated-name">@EliminatedName</div>
            </div>
        }

        @if ( !GameplayUiBlocked && RoundEndVisible )
        {
            <div class="round-overlay @RoundWinnerClass">
                <div class="round-winner-line">@RoundWinnerLabel</div>
                <div class="round-winner-sub">wins the round</div>
            </div>
        }

        @if ( ShowDroneLcdOverlay )
        {
            <DroneLcdOverlayPanel Hud=@this />
        }

        @if ( ShowDroneOpticOverlay )
        {
            <DroneOpticOverlayPanel Hud=@this />
        }

        @if ( ShowReticle )
        {
            <ReticlePanel Hud=@this />
        }

        @if ( !GameplayUiBlocked )
        {
            <RoundStatePanel Hud=@this />
            <KillFeedPanel Hud=@this />
        }

        @if ( !GameplayUiBlocked && LocalHealth is not null )
        {
            <HealthPanel Hud=@this />
        }

        @if ( ShowAmmoHud )
        {
            @AmmoHudRenderer.Render( LocalRole.ToString().ToLower(), AmmoHudLabel, AmmoHudValue )
        }

        @if ( ShowLoadoutHud )
        {
            <LoadoutPanel Hud=@this />
        }

        @if ( !GameplayUiBlocked && LocalRole == PlayerRole.Pilot )
        {
            <PilotControlsPanel Hud=@this />
        }

        @if ( !GameplayUiBlocked && ShowScoreboard )
        {
            @ScoreboardOverlayRenderer.Render( ScoreboardRows )
        }

        @if ( OptionsMenuOpen )
        {
            <OptionsOverlayPanel Hud=@this />
        }
    </div>
</root>

@code
{
    internal RoundManager Round => EnsureValid( ref _round );
    internal GameSetup Setup => EnsureValid( ref _setup );
    internal GameStats Stats => EnsureValid( ref _stats );
    internal KillFeedTracker KillFeed => EnsureValid( ref _killFeed );

    const string MenuClickSoundPath = "sounds/ui_menu_click.sound";
    const float MainMenuPlayTransitionSeconds = 0.5f;
    const float RolePickerEnterTransitionSeconds = 0.34f;
    const float MainMenuTransitionInactiveTime = -1000f;

    internal PlayerRole SelectedLoadoutTeam { get; set; } = PlayerRole.Spectator;
    internal int SelectedLoadoutSlot { get; set; } = 1;
    int ObservedSelectionGeneration { get; set; } = -1;
    bool MainMenuOpen { get; set; } = true;
    float _mainMenuPlayTransitionStartedAt = MainMenuTransitionInactiveTime;

    bool OptionsMenuOpen => LocalOptionsState.IsOpen;
    bool NeedsRoleChoice => Setup?.NeedsLocalRoleChoice() ?? false;
    bool ShowMainMenu => MainMenuOpen && NeedsRoleChoice;
    float MainMenuPlayTransitionElapsed => Time.Now - _mainMenuPlayTransitionStartedAt;
    internal bool PlayTransitionActive => NeedsRoleChoice
        && _mainMenuPlayTransitionStartedAt > 0f
        && MainMenuPlayTransitionElapsed < MainMenuPlayTransitionSeconds;
    internal bool RolePickerTransitionActive => NeedsRoleChoice
        && !MainMenuOpen
        && _mainMenuPlayTransitionStartedAt > 0f
        && MainMenuPlayTransitionElapsed >= MainMenuPlayTransitionSeconds
        && MainMenuPlayTransitionElapsed < MainMenuPlayTransitionSeconds + RolePickerEnterTransitionSeconds;
    bool ShowMainMenuShell => NeedsRoleChoice && (MainMenuOpen || PlayTransitionActive);
    bool ShowRolePicker => NeedsRoleChoice && !MainMenuOpen && !PlayTransitionActive;
    internal bool GameplayUiBlocked => ShowMainMenuShell || ShowRolePicker;
    internal string MainMenuShellClass => PlayTransitionActive
        ? "role-select main-menu-startup play-transition-exit"
        : "role-select main-menu-startup";
    internal string RolePickerShellClass => RolePickerTransitionActive
        ? "role-select play-transition-enter"
        : "role-select";
    internal int MainMenuTransitionHashTick => PlayTransitionActive || RolePickerTransitionActive
        ? (int)(MainMenuPlayTransitionElapsed * 30f)
        : -1;
    bool ShowLoadoutHud => !GameplayUiBlocked && !LocalDroneViewActive && LocalRole is PlayerRole.Pilot or PlayerRole.Soldier;
    internal bool ShowReticle => !GameplayUiBlocked && LocalRole is PlayerRole.Pilot or PlayerRole.Soldier;
    bool ShowDroneLcdOverlay => !GameplayUiBlocked
        && LocalDroneViewActive
        && LocalDroneCamera.IsValid()
        && LocalDroneCamera.IsFirstPersonActive;
    bool ShowDroneOpticOverlay => ShowDroneLcdOverlay
        && LocalDroneCamera.IsValid()
        && LocalDroneCamera.IsOpticZoomActive;
    internal bool ShowDroneActionPrompt => ShowReticle && LocalDroneViewActive && LocalDroneWeapon.IsValid();
    bool ShowScoreboard { get; set; }

    // ---- Hitmarker + damage feedback state (read by ReticlePanel) ----
    internal float _lastHitTime = -10f;
    internal float _lastKillTime = -10f;
    internal readonly List<DamageArc> _damageArcs = new();
    readonly Dictionary<Health, HealthEventHandlers> _healthHandlers = new();

    // ---- ELIMINATED popup + round transition state ----
    float _lastEliminatedTime = -10f;
    string _lastEliminatedName = "";
    RoundState _prevRoundState = RoundState.WaitingForPlayers;
    int _prevWinnerInt = -1;
    float _roundEndShownAt = -10f;       // when the win overlay should fade in

    /// <summary>Per-frame snapshot of damage indicators, age-faded.</summary>
    internal sealed class DamageArc
    {
        public float CreatedAt;
        public float AngleDeg;        // 0 = front, +90 = right
        public float Opacity;
    }

    sealed class HealthEventHandlers
    {
        public Action<DamageInfo> Damaged { get; init; }
        public Action<DamageInfo> Killed { get; init; }
    }

    string VignetteClass
    {
        get
        {
            var lowHp = LocalHealth is not null
                && LocalHealth.MaxHealth > 0f
                && (LocalHealth.CurrentHealth / LocalHealth.MaxHealth) < 0.25f;
            return lowHp ? "low-hp" : "";
        }
    }

    internal float SuppressionOpacity
    {
        get
        {
            var g = LocalGroundController;
            if ( !g.IsValid() ) return 0f;
            // Cap at 0.55 so the vignette never fully obscures the view.
            return MathF.Min( 0.55f, g.SuppressionT * 0.65f );
        }
    }

    bool EliminatedVisible => Time.Now - _lastEliminatedTime < 1.5f;
    string EliminatedName => _lastEliminatedName;

    bool RoundEndVisible
    {
        get
        {
            var round = Round;
            if ( round is null ) return false;
            if ( round.State != RoundState.Ended ) return false;
            if ( _roundEndShownAt < 0f ) return false;
            return (Time.Now - _roundEndShownAt) < 8f;
        }
    }

    string RoundWinnerLabel => Round?.LastWinnerInt switch
    {
        0 => "DRONE PILOTS WIN",
        1 => "HUNTERS WIN",
        _ => "ROUND OVER",
    };

    string RoundWinnerClass => Round?.LastWinnerInt switch
    {
        0 => "winner-pilot",
        1 => "winner-soldier",
        _ => "",
    };

    protected override void OnUpdate()
    {
        RefreshHudCache();
        SyncSelectionGeneration();
        HandleOptionsInput();
        LocalOptionsState.ApplyTo( Components.Get<ScreenPanel>() );
        if ( MainMenuOpen && !NeedsRoleChoice )
            MainMenuOpen = false;
        if ( !NeedsRoleChoice )
            _mainMenuPlayTransitionStartedAt = MainMenuTransitionInactiveTime;

        Mouse.Visibility = OptionsMenuOpen || GameplayUiBlocked
            ? MouseVisibility.Visible
            : MouseVisibility.Auto;

        if ( OptionsMenuOpen || GameplayUiBlocked )
            LocalOptionsState.ClearGameplayActions();

        var soldierLoadout = LocalSoldierComponent<SoldierLoadout>();
        if ( soldierLoadout.IsValid() )
            SelectedLoadoutSlot = soldierLoadout.ActiveSlot;

        if ( !OptionsMenuOpen && !soldierLoadout.IsValid() )
        {
            if ( Input.Pressed( "Slot1" ) )
                SelectedLoadoutSlot = 1;
            if ( Input.Pressed( "Slot2" ) )
                SelectedLoadoutSlot = 2;
        }

        ShowScoreboard = !OptionsMenuOpen && !GameplayUiBlocked && Input.Down( "Score" );

        // Subscribe to any new Health components — for hitmarker (we attacked
        // them) and damage-direction (we got hit).
        foreach ( var h in Scene.GetAllComponents<Health>() )
        {
            if ( !h.IsValid() ) continue;
            if ( _healthHandlers.ContainsKey( h ) ) continue;

            var victim = h;
            var handlers = new HealthEventHandlers
            {
                Damaged = info => OnAnyHealthDamaged( victim, info ),
                Killed = info => OnAnyHealthKilled( victim, info )
            };

            h.OnDamaged += handlers.Damaged;
            h.OnKilled += handlers.Killed;
            _healthHandlers[h] = handlers;
        }

        PruneHealthHandlers();

        // Round-state transitions: play swell on Countdown → Active, capture
        // round-end timestamp for the win overlay fade-in.
        var round = Round;
        if ( round is not null )
        {
            var state = round.State;
            if ( _prevRoundState == RoundState.Countdown && state == RoundState.Active )
                Sound.Play( "sounds/round_start_swell.sound" );

            if ( state == RoundState.Ended && _prevRoundState != RoundState.Ended )
                _roundEndShownAt = Time.Now;

            // Catch host's LastWinnerInt change separately in case the state
            // transition raced ahead.
            if ( round.LastWinnerInt != _prevWinnerInt && round.LastWinnerInt >= 0 )
            {
                _roundEndShownAt = Time.Now;
                _prevWinnerInt = round.LastWinnerInt;
            }

            _prevRoundState = state;
        }
    }

    void SyncSelectionGeneration()
    {
        var setup = Setup;
        if ( !setup.IsValid() )
            return;

        var generation = Math.Max( setup.SelectionGeneration, setup.LocalSelectionGeneration );
        if ( ObservedSelectionGeneration == generation )
            return;

        ObservedSelectionGeneration = generation;
        SelectedLoadoutTeam = PlayerRole.Spectator;
        SelectedLoadoutSlot = 1;
    }

    void HandleOptionsInput()
    {
        var escapePressed = Input.Keyboard.Pressed( "Escape" );
        var menuPressed = escapePressed || Input.Pressed( "Menu" );
        if ( menuPressed )
            LocalOptionsState.ToggleOpen();
    }

    internal void ClickMenuOption( Action action )
    {
        PlayMenuClickSound();
        action?.Invoke();
    }

    void PlayMenuClickSound()
    {
        Sound.Play( MenuClickSoundPath );
    }

    void StartFromMainMenu()
    {
        MainMenuOpen = false;
        SelectedLoadoutTeam = PlayerRole.Spectator;
        LocalOptionsState.SetOpen( false );
        _mainMenuPlayTransitionStartedAt = MainMenuTransitionInactiveTime;
    }

    internal void StartMainMenuPlayTransition()
    {
        if ( PlayTransitionActive )
            return;

        if ( !NeedsRoleChoice )
        {
            StartFromMainMenu();
            return;
        }

        MainMenuOpen = false;
        SelectedLoadoutTeam = PlayerRole.Spectator;
        LocalOptionsState.SetOpen( false );
        _mainMenuPlayTransitionStartedAt = Time.Now;
    }

    internal void OpenMainMenuOptions()
    {
        LocalOptionsState.SetOpen( true );
    }

    internal void SelectPilotTeam()
    {
        SelectLoadoutTeam( PlayerRole.Pilot );
    }

    internal void SelectSoldierTeam()
    {
        SelectLoadoutTeam( PlayerRole.Soldier );
    }

    internal void SelectGpsDrone()
    {
        Setup?.SelectLocalDrone( DroneType.Gps );
    }

    internal void SelectFpvDrone()
    {
        Setup?.SelectLocalDrone( DroneType.Fpv );
    }

    internal void SelectFiberFpvDrone()
    {
        Setup?.SelectLocalDrone( DroneType.FiberOpticFpv );
    }

    internal void SelectAssaultSoldier()
    {
        Setup?.SelectLocalSoldier( SoldierClass.Assault );
    }

    internal void SelectCounterUavSoldier()
    {
        Setup?.SelectLocalSoldier( SoldierClass.CounterUav );
    }

    internal void SelectHeavySoldier()
    {
        Setup?.SelectLocalSoldier( SoldierClass.Heavy );
    }

    internal void ResumeOptions()
    {
        LocalOptionsState.SetOpen( false );
    }

    internal void IncreaseUiScale()
    {
        LocalOptionsState.AdjustUiScale( LocalOptionsState.UiScaleStep );
    }

    internal void DecreaseUiScale()
    {
        LocalOptionsState.AdjustUiScale( -LocalOptionsState.UiScaleStep );
    }

    internal void ResetUiScale()
    {
        LocalOptionsState.ResetUiScale();
    }

    internal void IncreaseLookSensitivity()
    {
        LocalOptionsState.AdjustLookSensitivity( LocalOptionsState.LookSensitivityStep );
    }

    internal void DecreaseLookSensitivity()
    {
        LocalOptionsState.AdjustLookSensitivity( -LocalOptionsState.LookSensitivityStep );
    }

    internal void LeaveMatch()
    {
        LocalOptionsState.SetOpen( false );
        Game.Disconnect();
    }

    internal void QuitGame()
    {
        LocalOptionsState.SetOpen( false );
        Game.Close();
    }

    protected override void OnDestroy()
    {
        foreach ( var (health, handlers) in _healthHandlers )
        {
            if ( !health.IsValid() ) continue;
            health.OnDamaged -= handlers.Damaged;
            health.OnKilled -= handlers.Killed;
        }

        _healthHandlers.Clear();
    }

    void PruneHealthHandlers()
    {
        var stale = _healthHandlers.Keys.Where( h => !h.IsValid() ).ToList();
        foreach ( var health in stale )
            _healthHandlers.Remove( health );
    }

    void OnAnyHealthDamaged( Health victim, DamageInfo info )
    {
        var localId = Connection.Local?.Id ?? default;
        if ( localId == default ) return;

        // We hit someone — hitmarker for the local attacker.
        if ( info.AttackerId == localId && victim.GameObject.Network.Owner?.Id != localId )
        {
            _lastHitTime = Time.Now;
            Sound.Play( "sounds/ui_hitmarker.sound" );
        }

        // We got hit — damage direction arc pointing at the attacker.
        if ( victim.GameObject.Network.Owner?.Id == localId && info.AttackerId != default && info.AttackerId != localId )
        {
            var localPos = LocalCameraPosition;
            var sourcePos = info.Position;
            var toSource = (sourcePos - localPos).WithZ( 0 );
            if ( toSource.IsNearZeroLength ) return;

            // Angle clockwise from local forward (camera yaw).
            var forward = LocalCameraForward.WithZ( 0 ).Normal;
            var right = Vector3.Cross( Vector3.Up, forward ).Normal;
            var dirN = toSource.Normal;
            var angleRad = MathF.Atan2( Vector3.Dot( dirN, right ), Vector3.Dot( dirN, forward ) );
            var angleDeg = angleRad * 180f / MathF.PI;

            _damageArcs.Add( new DamageArc { CreatedAt = Time.Now, AngleDeg = angleDeg, Opacity = 0.9f } );
            if ( _damageArcs.Count > 8 )
                _damageArcs.RemoveAt( 0 );
        }
    }

    void OnAnyHealthKilled( Health victim, DamageInfo info )
    {
        var localId = Connection.Local?.Id ?? default;
        if ( localId == default ) return;

        if ( info.AttackerId == localId && victim.GameObject.Network.Owner?.Id != localId )
        {
            _lastKillTime = Time.Now;
            _lastEliminatedTime = Time.Now;
            _lastEliminatedName = ResolveVictimName( victim );
            Sound.Play( "sounds/ui_hitmarker_kill.sound" );
        }
    }

    string ResolveVictimName( Health victim )
    {
        var connId = victim.GameObject.Network.Owner?.Id ?? default;
        if ( connId == default ) return victim.GameObject.Name ?? "Target";

        var stats = Stats;
        if ( stats.IsValid() && stats.PlayerNames.TryGetValue( connId, out var name ) && !string.IsNullOrWhiteSpace( name ) )
            return name;

        var conn = Connection.All.FirstOrDefault( c => c.Id == connId );
        return conn?.DisplayName ?? "Target";
    }

    Vector3 LocalCameraPosition =>
        _sceneCamera.IsValid() ? _sceneCamera.WorldPosition : Vector3.Zero;

    Vector3 LocalCameraForward =>
        _sceneCamera.IsValid() ? _sceneCamera.WorldRotation.Forward : Vector3.Forward;

    internal RemoteController LocalRemoteController => _localRemote;

    float SunGlareOpacity
    {
        get
        {
            var source = EnsureValid( ref _sunGlareSource );
            if ( !source.IsValid() || !source.Enabled )
                return 0f;

            var remote = LocalRemoteController;
            var droneViewActive = remote.IsValid() && remote.DroneViewActive;

            return source.GetGlareOpacity( LocalCameraPosition, LocalCameraForward, LocalRole, droneViewActive );
        }
    }

    void SelectLoadoutTeam( PlayerRole team )
    {
        if ( team is not (PlayerRole.Pilot or PlayerRole.Soldier) )
            return;

        SelectedLoadoutTeam = team;
    }

    internal void BackToMainMenu()
    {
        MainMenuOpen = true;
        _mainMenuPlayTransitionStartedAt = MainMenuTransitionInactiveTime;
        ClearLoadoutTeam();
    }

    internal void ClearLoadoutTeam()
    {
        SelectedLoadoutTeam = PlayerRole.Spectator;
        SelectedLoadoutSlot = 1;
    }

    internal LoadoutDefinitionResource SoldierDefinition( SoldierClass cls ) =>
        Setup?.GetSoldierLoadoutDefinition( cls ) ?? LoadoutCatalog.FindSoldier( null, cls );

    internal LoadoutDefinitionResource DroneDefinition( DroneType type ) =>
        Setup?.GetDroneLoadoutDefinition( type ) ?? LoadoutCatalog.FindDrone( null, type );

    internal int LoadoutPreviewHash => HashCode.Combine(
        SoldierDefinition( SoldierClass.Assault )?.StableHash ?? 0,
        SoldierDefinition( SoldierClass.CounterUav )?.StableHash ?? 0,
        SoldierDefinition( SoldierClass.Heavy )?.StableHash ?? 0,
        DroneDefinition( DroneType.Gps )?.StableHash ?? 0,
        DroneDefinition( DroneType.Fpv )?.StableHash ?? 0,
        DroneDefinition( DroneType.FiberOpticFpv )?.StableHash ?? 0 );

    internal T LocalSoldierComponent<T>() where T : Component
    {
        var ground = LocalGroundController;
        return ground.IsValid()
            ? ground.GameObject.Components.Get<T>( FindMode.EverythingInSelfAndDescendants )
            : null;
    }

    internal GroundPlayerController LocalGroundController => _localGround;

    internal PilotSoldier LocalPilotSoldier => _localPilot;

    internal DroneController LocalDroneController => _localDrone;

    internal DroneWeapon LocalDroneWeapon => _localDroneWeapon;

    internal WorldInteractionPrompt CurrentWorldPrompt => _worldPrompt;

    internal string DroneActionLabel
    {
        get
        {
            var weapon = LocalDroneWeapon;
            if ( !weapon.IsValid() )
                return "";

            if ( weapon.PrimaryUsesKamikaze )
                return "DETONATE";

            if ( LocalDroneBase.IsValid() && LocalDroneBase.Type == DroneType.Gps )
                return "GPS LASER";

            if ( weapon.EnableHitscan )
                return "LASER";

            return weapon.EnableKamikaze ? "DETONATE" : "";
        }
    }

    internal string DroneLcdVariantLabel => LocalDroneBase.IsValid()
        ? LocalDroneBase.Type switch
        {
            DroneType.Gps => "GPS CAMERA",
            DroneType.Fpv => "FPV CAMERA",
            DroneType.FiberOpticFpv => "FIBER FPV",
            _ => "DRONE CAMERA",
        }
        : "DRONE CAMERA";

    internal string DroneVariantClass => LocalDroneBase.IsValid()
        ? LocalDroneBase.Type switch
        {
            DroneType.Gps => "gps",
            DroneType.Fpv => "fpv",
            DroneType.FiberOpticFpv => "fpv fiber",
            _ => "drone",
        }
        : "drone";

    internal SoldierClass LocalSoldierClass
    {
        get
        {
            var soldier = LocalSoldierComponent<SoldierBase>();
            return soldier.IsValid() ? soldier.Class : SoldierClass.Assault;
        }
    }

    internal string DroneOpticZoomLabel => LocalDroneCamera.IsValid()
        ? $"{LocalDroneCamera.OpticZoomFovDegrees:0} FOV"
        : "";

    internal DroneType LocalDroneType
    {
        get
        {
            if ( LocalDroneBase.IsValid() )
                return LocalDroneBase.Type;

            var pilot = LocalPilotSoldier;
            return pilot.IsValid() ? pilot.ChosenDrone : DroneType.Gps;
        }
    }

    internal string LocalSoldierName
    {
        get
        {
            var definition = SoldierDefinition( LocalSoldierClass );
            return string.IsNullOrWhiteSpace( definition?.DisplayName )
                ? SoldierClassName( LocalSoldierClass )
                : definition.DisplayName;
        }
    }

    internal string LocalDroneName
    {
        get
        {
            var definition = DroneDefinition( LocalDroneType );
            return string.IsNullOrWhiteSpace( definition?.DisplayName )
                ? DroneVariantName( LocalDroneType )
                : definition.DisplayName;
        }
    }

    internal static string SoldierClassName( SoldierClass cls ) => cls switch
    {
        SoldierClass.Assault => "Assault",
        SoldierClass.CounterUav => "Counter-UAV",
        SoldierClass.Heavy => "Heavy",
        _ => "Hunter",
    };

    internal static string DroneVariantName( DroneType type ) => type switch
    {
        DroneType.Gps => "GPS Drone",
        DroneType.Fpv => "FPV Drone",
        DroneType.FiberOpticFpv => "Fiber FPV",
        _ => "Drone",
    };

    HitscanWeapon CurrentRifleAmmoWeapon => _activeRifle;

    ShotgunWeapon CurrentShotgunAmmoWeapon => _activeShotgun;

    bool ShowAmmoHud => ShowLoadoutHud
        && !LocalDroneViewActive
        && (CurrentRifleAmmoWeapon.IsValid() || CurrentShotgunAmmoWeapon.IsValid());

    string AmmoHudLabel
    {
        get
        {
            if ( CurrentRifleAmmoWeapon.IsValid() )
                return (CurrentRifleAmmoWeapon.WeaponDisplayName ?? "Ammo").ToUpperInvariant();

            if ( CurrentShotgunAmmoWeapon.IsValid() )
                return (CurrentShotgunAmmoWeapon.WeaponDisplayName ?? "Ammo").ToUpperInvariant();

            return "";
        }
    }

    string AmmoHudValue
    {
        get
        {
            if ( CurrentRifleAmmoWeapon.IsValid() )
                return CurrentRifleAmmoWeapon.AmmoDisplay;

            if ( CurrentShotgunAmmoWeapon.IsValid() )
                return CurrentShotgunAmmoWeapon.AmmoDisplay;

            return "";
        }
    }

    float CurrentWeaponBloom
    {
        get
        {
            if ( CurrentRifleAmmoWeapon.IsValid() )
                return CurrentRifleAmmoWeapon.CurrentAimBloom;

            if ( CurrentShotgunAmmoWeapon.IsValid() )
                return CurrentShotgunAmmoWeapon.CurrentAimBloom;

            return 0f;
        }
    }

    internal int CurrentWeaponBloomBucket => Math.Clamp( (int)MathF.Ceiling( CurrentWeaponBloom * 2f ), 0, 8 );

    internal int JammerBatteryBucket
    {
        get
        {
            var jammer = _activeJammerGun;
            return jammer.IsValid() ? Math.Clamp( (int)MathF.Ceiling( jammer.BatteryChargeFraction * 20f ), 0, 20 ) : -1;
        }
    }

    internal bool LocalDroneViewActive
    {
        get
        {
            var remote = LocalRemoteController;
            return remote.IsValid() && remote.DroneViewActive;
        }
    }

    JammingReceiver LocalJammer => _localJammer;

    bool ShowJamWarning => LocalRole == PlayerRole.Pilot
        && LocalJammer.IsValid()
        && LocalJammer.IsJammed
        && LocalDroneBase.IsValid()
        && LocalDroneBase.JamSusceptibility > 0.01f;

    internal DroneBase LocalDroneBase => _localDroneBase;

    internal Health LocalHealth => _localHealth;

    internal PlayerRole LocalRole
    {
        get
        {
            if ( _localDrone.IsValid() ) return PlayerRole.Pilot;
            if ( _localPilot.IsValid() ) return PlayerRole.Pilot;
            if ( _localGround.IsValid() ) return PlayerRole.Soldier;

            return PlayerRole.Spectator;
        }
    }

    internal DroneCamera LocalDroneCamera => _localDroneCamera;

    internal int PilotWins => Round?.PilotWins ?? 0;
    internal int SoldierWins => Round?.SoldierWins ?? 0;

    IReadOnlyList<ScoreboardRow> ScoreboardRows
    {
        get
        {
            var stats = Stats;
            if ( stats is null ) return Array.Empty<ScoreboardRow>();
            return stats.GetScoreboard()
                .Select( s => new ScoreboardRow( s.Name, s.Kills, s.Deaths, s.Score ) )
                .ToList();
        }
    }

    int ScoreboardRowsHash
    {
        get
        {
            if ( !ShowScoreboard ) return 0;
            var hash = 17;
            foreach ( var row in ScoreboardRows )
                hash = HashCode.Combine( hash, row.Name, row.Kills, row.Deaths, row.Score );
            return hash;
        }
    }

    /// <summary>
    /// Re-render gate for the parent shell only: section visibility gates,
    /// the alert overlays the parent still renders inline, and the ammo
    /// readout. Each child panel owns the hash for its own slice, so an
    /// idle HUD no longer rebuilds at the reticle's animation tick rate.
    /// </summary>
    protected override int BuildHash()
    {
        return HashCode.Combine(
            HashCode.Combine(
                ShowMainMenuShell, ShowRolePicker, GameplayUiBlocked,
                OptionsMenuOpen, ShowScoreboard, ShowReticle,
                ShowLoadoutHud, ShowAmmoHud
            ),
            HashCode.Combine(
                LocalRole, LocalHealth is not null, VignetteClass,
                ShowDroneLcdOverlay, ShowDroneOpticOverlay, ShowJamWarning
            ),
            HashCode.Combine(
                RoundEndVisible, RoundWinnerLabel,
                EliminatedVisible, EliminatedName,
                (int)(SuppressionOpacity * 50f),
                (int)(SunGlareOpacity * 100f)
            ),
            HashCode.Combine( AmmoHudLabel, AmmoHudValue ),
            ScoreboardRowsHash
        );
    }
}
